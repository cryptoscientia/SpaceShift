  "market_crafting_tuning": {
    "flags": {
      "enable_dynamic_substitutions": true,
      "enforce_substitution_network_caps": true,
      "apply_scarcity_to_crafting_quotes": true,
      "enable_volatility_damping": true,
      "enable_stockpile_release_damping": true,
      "use_weighted_moving_average_midprice": true
    },
    "parameters": {
      "max_substitution_relief": 0.55,
      "scarcity_shock_gain": 0.65,
      "byproduct_rigidity_gain": 0.4,
      "strategic_stockpile_buffer": 0.35,
      "liquidity_depth_default": 0.5,
      "volatility_damping_strength": 0.45,
      "volatility_smoothing_window_days": 7,
      "max_period_price_step_pct": 0.18,
      "credit_markup_for_low_fidelity_substitution": 0.08
    },
    "formulas": {
      "effective_scarcity_index": "class.base_scarcity_index * (1 + scarcity_shock_gain * supply_shock) * (1 + class.stockpiling_sensitivity * strategic_demand) * (1 - substitution_relief)",
      "substitution_relief": "clamp(substitution_coverage * avg_substitution_fidelity * class.substitution_elasticity, 0, max_substitution_relief)",
      "crafting_material_multiplier": "effective_scarcity_index * (1 + class.byproduct_dependency * byproduct_rigidity_gain * demand_acceleration)",
      "volatility_undamped": "class.baseline_volatility * (1 + effective_scarcity_index - 1 + supply_shock) * (1 + demand_acceleration)",
      "volatility_damped": "clamp(volatility_undamped * (1 - volatility_damping_strength * (liquidity_depth + strategic_stockpile_buffer)), 0.02, 0.3)",
      "midprice_next": "midprice_prev * (1 + clamp(order_flow_imbalance, -max_period_price_step_pct, max_period_price_step_pct))"
    }
  }
